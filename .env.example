# groundctl-ugv environment variables
#
# Setup:
#   cp .env.example .env
#   # fill in the values below with your own credentials and addresses
#
# How it's loaded:
#   - Mac-side: heartbeat.py uses python-dotenv to load .env automatically
#     from the working directory. start_ros2.sh sources it directly.
#   - Rover-side: after deploy, copy .env to ~/.groundctl.env on the rover
#     and chmod 600. systemd-user services read it via EnvironmentFile.
#
# .env is in .gitignore — never commit your filled-in values.

# ============================================================================
# API keys (required)
# ============================================================================

# Anthropic API key — drives Haiku heartbeat + Sonnet/Opus conversation
# Get one from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Deepgram API key — Nova-2 streaming STT (listener_daemon) + Aura-2
# Hyperion TTS (heartbeat's exec_speak). Get one from https://deepgram.com/
DEEPGRAM_API_KEY=...

# ============================================================================
# Network endpoints (required)
# ============================================================================

# Rover IP — Tailscale (preferred) or LAN address of the Jetson Orin Nano
# running the bridge. Port 5000 (bridge HTTP) and 5060 (control_panel) are
# implied; don't include them here.
ROVER_IP=100.x.x.x

# Same address, no scheme — used by the bash deploy scripts (start_ros2.sh,
# stop_ros2.sh). Usually identical to ROVER_IP.
ROVER=100.x.x.x

# SSH user on the rover. Default if unset: jetson
# ROVER_USER=jetson

# Docker container hosting the ROS2 stack. Default if unset: ugv_jp6
# CONTAINER=ugv_jp6

# ============================================================================
# Oneiro memory (optional)
# ============================================================================

# Oneiro MCP endpoint — one Cloudflare Workers URL serves both directions,
# authed with a single rover-scoped bearer key:
#   - Reads:  attached to Haiku via the Anthropic mcp_servers connector,
#             restricted to recall_* (recall_orient/check/specific/image).
#   - Writes: heartbeat's exec_remember() POSTs a tools/call to
#             remember_with_image directly, attaching the current camera frame.
# The rover key's server-side role permits recall_* + remember*; forget, reframe
# and reflect are rejected at dispatch. Leave empty to keep the rover
# observe-and-forget — the heartbeat runs fine without it.
# Format: https://<host>/mcp (the MCP streamable-HTTP endpoint)
ONEIRO_MCP_URL=
ONEIRO_MCP_TOKEN=

# ============================================================================
# AusCORS NTRIP for RTK GPS (optional)
# ============================================================================

# Australian readers: get free NTRIP credentials at https://gnss.ga.gov.au/auscors
# Required only if the ZED-F9R RTK GPS is installed and you want
# centimetre-precision positioning. Standard GNSS (~2.5m accuracy) works
# without NTRIP.
AUSCORS_NTRIP_USER=
AUSCORS_NTRIP_PASS=
# AUSCORS_NTRIP_HOST=ntrip.data.gnss.ga.gov.au
# AUSCORS_NTRIP_PORT=443
# AUSCORS_MOUNTPOINT=RSBY00AUS0   # change to nearest base station for your region
